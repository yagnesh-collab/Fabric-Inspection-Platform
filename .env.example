# ============================================================
#  .env.example — copy to .env and fill in your own secrets
#  Safe to commit — contains no real credentials
# ============================================================

# IMPORTANT: Do NOT use @ # % + in passwords — these break URL parsing in
# DATABASE_URL and RABBITMQ_URL. Use letters, digits, and _ only.
POSTGRES_USER=nextex
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=nextex

RABBITMQ_DEFAULT_USER=change_me_user
RABBITMQ_DEFAULT_PASS=change_me_strong_password

DATABASE_URL=postgresql+asyncpg://nextex:change_me_strong_password@postgres:5432/nextex
RABBITMQ_URL=amqp://change_me_user:change_me_strong_password@rabbitmq:5672/

# Generate with: python3 -c "import secrets; print('nx-' + secrets.token_hex(16))"
API_KEY=change_me_api_key

FRAME_INTERVAL_MS=800
ANOMALY_THRESHOLD=0.75
DATASET_PATH=/data/images

ALLOWED_ORIGIN=http://localhost:3000
